{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/og",
      "destination": "/api/og"
    },
    {
      "source": "/api/:path*",
      "destination": "https://cashout-production.up.railway.app/api/:path*"
    }
  ]
}
